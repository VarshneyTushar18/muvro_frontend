{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/technology",
      "status": 308,
      "headers": {
        "Location": "/technologies"
      }
    },
    {
      "src": "/technologgy",
      "status": 308,
      "headers": {
        "Location": "/technologies"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
